# ──────────────────────────────────────────────────────────────
# Neon Postgres
# Pooled (con `-pooler` en el host): para queries normales.
# Direct (sin `-pooler`): para migraciones Prisma.
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────
# NextAuth (Auth.js v5)
# ──────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────
# Cifrado en reposo (API keys, configuración sensible)
# Debe ser una clave hex de 32 bytes (64 hex chars).
# Generar con: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=""

# ──────────────────────────────────────────────────────────────
# Redis (Upstash) — cola BullMQ
# ──────────────────────────────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# ──────────────────────────────────────────────────────────────
# Cloudflare R2 (almacenamiento de archivos)
# ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="tavex-archivos"
R2_PUBLIC_URL=""   # opcional: dominio público si configurado

# ──────────────────────────────────────────────────────────────
# Gemini (fallback global; cada organización puede tener la suya cifrada)
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-pro"

# ──────────────────────────────────────────────────────────────
# Recuperación de contraseña (forgot password)
# ──────────────────────────────────────────────────────────────
# (opcional) API key de Resend para envío de emails (https://resend.com).
# Sin esta variable el enlace de reset se loguea a stdout en lugar de enviarse.
# En Fly: fly secrets set RESEND_API_KEY=re_xxxx -a tavex
RESEND_API_KEY=""

# (opcional) Dirección remitente de los emails transaccionales.
EMAIL_FROM="Tavex <noreply@tavex.fly.dev>"

# (opcional) URL pública de la app, usada en los enlaces de los emails de reset.
# Si no se configura, se infiere del header `host` del request entrante.
APP_URL="https://tavex.fly.dev"
